# ============================================================
# RESQ-AI  |  Environment Variables
# File: backend/.env
#
# Copy this file to backend/.env and fill in your real values.
# NEVER commit .env to git. Add it to .gitignore.
# ============================================================

# ── Feature 5: Twilio (SMS + WhatsApp) ──────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX          # Your Twilio SMS number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Twilio sandbox (dev) or approved sender

# ── Feature 1: Claude AI (Early Warning Prediction) ─────────
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Feature 3: OpenRouteService (Evacuation Routing) ────────
# Get free key from https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key_here

# ── Server ───────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
